configs/*/logs/
configs/*/*.json
configs/*/.config.runtime.yaml
configs/*/config.yaml
**/main.log

# CLIProxyAPI binary executables are NOT tracked in git.
# Use `python3 core/binary_updater.py` to download them.
CLIProxyAPI/linux/amd64/cli-proxy-api
CLIProxyAPI/linux/arm64/cli-proxy-api
CLIProxyAPI/windows/amd64/cli-proxy-api.exe

# PID files (Linux process tracking)
configs/*/.proxy.pid

# Management UI assets (바이너리가 런타임에 자동 생성)
configs/*/static/
static/

# Python bytecode cache
core/__pycache__/
**/*.pyc

# Shell script backups (one-time migration artifacts)
shell/bash/cc-proxy.sh.bak
shell/powershell/cc-proxy.ps1.bak
